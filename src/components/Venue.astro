---
---

<section id="venue" class="py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="font-serif italic text-gold text-lg mb-2">Where we'll be</p>
      <h2 class="font-serif text-4xl sm:text-5xl font-bold text-wine">La Fabrique des Ducs</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <div>
        <p class="text-charcoal/80 text-lg leading-relaxed mb-6">
          Nestled in the heart of Burgundy, La Fabrique des Ducs is a stunning 1,000&nbsp;m&sup2;
          estate that can accommodate up to 64 guests. This beautifully restored property by
          <strong>Vindihouses</strong> features 7 apartments with 22 bedrooms and 37 beds &mdash;
          more than enough room for all of us.
        </p>
        <p class="text-charcoal/80 text-lg leading-relaxed mb-8">
          The property includes a heated swimming pool (with a retractable dome), a professional
          kitchen for our group meals, a game room for the kids, large terraces for aperitifs at
          sunset, and generous outdoor grounds for everyone to enjoy.
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-8">
          <div class="bg-white rounded-xl p-4 text-center shadow-sm">
            <span class="text-2xl mb-1 block">🏊</span>
            <span class="text-sm text-charcoal/70">Heated Pool</span>
          </div>
          <div class="bg-white rounded-xl p-4 text-center shadow-sm">
            <span class="text-2xl mb-1 block">👨‍🍳</span>
            <span class="text-sm text-charcoal/70">Pro Kitchen</span>
          </div>
          <div class="bg-white rounded-xl p-4 text-center shadow-sm">
            <span class="text-2xl mb-1 block">🎮</span>
            <span class="text-sm text-charcoal/70">Game Room</span>
          </div>
          <div class="bg-white rounded-xl p-4 text-center shadow-sm">
            <span class="text-2xl mb-1 block">📶</span>
            <span class="text-sm text-charcoal/70">Wi-Fi</span>
          </div>
          <div class="bg-white rounded-xl p-4 text-center shadow-sm">
            <span class="text-2xl mb-1 block">🛏️</span>
            <span class="text-sm text-charcoal/70">64 Guests</span>
          </div>
          <div class="bg-white rounded-xl p-4 text-center shadow-sm">
            <span class="text-2xl mb-1 block">♿</span>
            <span class="text-sm text-charcoal/70">Accessible</span>
          </div>
        </div>

        <a href="https://www.vindihouses.com/fr/chambre/la-fabrique-des-ducs" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 text-wine font-medium hover:text-wine-dark transition-colors">
          View the full property on Vindihouses
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>

      <div class="space-y-6">
        <div class="rounded-2xl overflow-hidden shadow-lg aspect-video bg-cream-dark">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2738.5!2d4.5193!3d46.9893!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47f2208e8ad2c4fb%3A0x8f5e21f8cf2e6e0!2sLa+Fabrique+des+Ducs+By+Vindihouses!5e0!3m2!1sen!2sfr!4v1700000000000!5m2!1sen!2sfr"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="La Fabrique des Ducs location">
          </iframe>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-serif text-xl font-semibold text-wine mb-2">Address</h3>
          <p class="text-charcoal/70">
            La Fabrique des Ducs<br/>
            Epinac, 71360<br/>
            Saône-et-Loire, Burgundy, France
          </p>
          <a href="https://www.google.com/maps/dir//La+Fabrique+des+Ducs+Epinac" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1 text-gold-dark font-medium mt-3 hover:text-wine transition-colors text-sm">
            Get directions on Google Maps
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
