---
/**
 * Icons use 512×512 JPEGs from scripts/normalize-illustration-icons.py (per-image frame removal).
 */
interface Props {
  src: string;
  alt: string;
  size?: "sm" | "md" | "lg" | "xl";
  class?: string;
}

const { src, alt, size = "md", class: className = "" } = Astro.props;

// Edge length ~½ previous step (¼ prior surface area vs original 8rem xl)
const box: Record<NonNullable<Props["size"]>, string> = {
  sm: "h-[0.815rem] w-[0.815rem]",
  md: "h-[1.02rem] w-[1.02rem]",
  lg: "h-[1.225rem] w-[1.225rem]",
  xl: "h-[3.265rem] w-[3.265rem]",
};

const cls = [
  box[size],
  "block shrink-0 m-0 max-h-none max-w-none p-0 align-middle",
  "object-cover object-center",
  "border-0 outline-none ring-0 shadow-none",
  className,
].filter(Boolean).join(" ");
---

<img src={src} alt={alt} class={cls} loading="lazy" decoding="async" />
