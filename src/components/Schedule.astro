---
---

<section id="schedule" class="py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="font-serif italic text-gold text-lg mb-2">The week ahead</p>
      <h2 class="font-serif text-4xl sm:text-5xl font-bold text-wine">Schedule</h2>
      <div class="w-16 h-px bg-gold mx-auto mt-6"></div>
      <p class="mt-6 text-charcoal/70 max-w-2xl mx-auto">
        Seven days of adventure, relaxation, great food, and celebrating together.
        Each day has a loose plan &mdash; you&rsquo;re free to join in or do your own thing.
      </p>
    </div>

    <div class="space-y-8">

      <!-- July 4 -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-blue-800 via-red-700 to-blue-800 p-6 text-white">
          <div class="flex items-center justify-between flex-wrap gap-2">
            <div>
              <p class="text-white/70 text-sm uppercase tracking-wider">Saturday, July 4</p>
              <h3 class="font-serif text-2xl sm:text-3xl font-bold">250th Independence Day Party 🇺🇸</h3>
            </div>
            <span class="bg-white/20 px-4 py-1 rounded-full text-sm">Arrival Day</span>
          </div>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">☀️</span> Daytime
              </h4>
              <p class="text-charcoal/70">
                Arrivals and settling in. Explore the estate, take a dip in the pool,
                and get to know the space. We&rsquo;ll have drinks and snacks ready for you.
              </p>
            </div>
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">🌙</span> Evening
              </h4>
              <p class="text-charcoal/70 mb-3">
                <strong>BBQ &amp; themed party!</strong> Dress code: red, white &amp; blue.
                American-themed food and cocktails on the terrace. Sparklers for the kids.
              </p>
              <a href="https://open.spotify.com/playlist/YOUR_PLAYLIST_ID" target="_blank" rel="noopener"
                 class="inline-flex items-center gap-2 text-sm text-green-600 font-medium hover:text-green-700">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                Contribute to the July 4th Playlist
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- July 5 -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-sage to-sage-light p-6 text-white">
          <p class="text-white/70 text-sm uppercase tracking-wider">Sunday, July 5</p>
          <h3 class="font-serif text-2xl sm:text-3xl font-bold">Adventure Day 🚴</h3>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid md:grid-cols-3 gap-8">
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">🌅</span> Morning
              </h4>
              <p class="text-charcoal/70">
                <strong>Cycling on the Voie Verte</strong> &mdash; a flat, scenic former railway path
                that starts right in Epinac. Perfect for families. Bikes (including kids&rsquo; bikes
                and e-bikes) rented from Morvan Bike Autun.
              </p>
            </div>
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">☀️</span> Afternoon
              </h4>
              <p class="text-charcoal/70">
                <strong>Base de Loisirs de la Dr&eacute;e</strong> &mdash; right here in Epinac!
                Mini-golf, playground, ping-pong, baby-foot, and a lovely picnic area by the river.
              </p>
            </div>
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">🌙</span> Evening
              </h4>
              <p class="text-charcoal/70">
                Chill night at the venue. Ap&eacute;ritif by the pool, casual dinner
                together, board games, and settling in for the week.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- July 6 -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-wine to-wine-light p-6 text-white">
          <p class="text-white/70 text-sm uppercase tracking-wider">Monday, July 6</p>
          <h3 class="font-serif text-2xl sm:text-3xl font-bold">Wine &amp; Castle Day 🏰</h3>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid md:grid-cols-2 gap-8 mb-8">
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">☀️</span> Day Trip
              </h4>
              <p class="text-charcoal/70">
                Group excursion to <strong>Ch&acirc;teau de Couches</strong> (25-min drive) &mdash;
                an 11th-century castle with wine tastings (6 wines), towers, underground passages,
                and grounds that kids will love exploring. &euro;14/adult, &euro;4/child.
              </p>
            </div>
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">🍷</span> Late Afternoon
              </h4>
              <p class="text-charcoal/70">
                Stop at <strong>Cave Laly in Autun</strong> for wine shopping, or explore
                a second winery along the Route des Vins du Couchois.
              </p>
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-wine mb-4 flex items-center gap-2">
              <span class="text-lg">🌙</span> Dinner Options
            </h4>
            <p class="text-charcoal/60 text-sm mb-4">Eat at the venue, or pick one of these nearby restaurants (book on your own):</p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
              <a href="http://lechateaubriant.com/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Le Ch&acirc;teaubriant</h5>
                <p class="text-xs text-charcoal/60 mt-1">Autun &middot; 20 min &middot; Burgundy gastronomy &middot; Kids menu &euro;10</p>
                <p class="text-xs text-gold-dark mt-2">Tel: 03 85 52 21 58</p>
              </a>
              <a href="https://labrasseriedeshalles.fr/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">La Brasserie des Halles</h5>
                <p class="text-xs text-charcoal/60 mt-1">Nolay &middot; 30 min &middot; Burgundy cuisine &amp; wine bar &middot; 4.5/5</p>
                <p class="text-xs text-gold-dark mt-2">Tel: 03 80 20 64 40</p>
              </a>
              <a href="https://fr.restaurantguru.com/Au-Tire-Bouchon-Nolay" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Au Tire Bouchon</h5>
                <p class="text-xs text-charcoal/60 mt-1">Nolay &middot; 30 min &middot; French traditional &middot; Terrace &middot; 4.5/5</p>
                <p class="text-xs text-gold-dark mt-2">&euro;20-30 per person</p>
              </a>
              <a href="https://www.autun-tourisme.com/offres/a-lheure-des-saveurs-couches-fr-4999013/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">A l&rsquo;Heure des Saveurs</h5>
                <p class="text-xs text-charcoal/60 mt-1">Couches &middot; 25 min &middot; Regional Burgundy &middot; 78 covers</p>
                <p class="text-xs text-gold-dark mt-2">Lunch &amp; Sat dinner</p>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- July 7 -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-blue-500 to-cyan-400 p-6 text-white">
          <p class="text-white/70 text-sm uppercase tracking-wider">Tuesday, July 7</p>
          <h3 class="font-serif text-2xl sm:text-3xl font-bold">Lake Day 🚣</h3>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid md:grid-cols-2 gap-8 mb-8">
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">☀️</span> Full Day Excursion
              </h4>
              <p class="text-charcoal/70 mb-3">
                <strong>Lac des Settons</strong> &mdash; a stunning 366-hectare lake in the heart
                of the Morvan Natural Park (~1h15 drive).
              </p>
              <ul class="space-y-2 text-charcoal/70 text-sm">
                <li class="flex items-start gap-2">
                  <span class="text-gold">&#9679;</span>
                  <span>Sailing school, kayak, paddleboard &amp; pedalo rental (Settons Nautisme)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold">&#9679;</span>
                  <span>Inflatable water park on the lake &mdash; kids will love it!</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold">&#9679;</span>
                  <span>Supervised swimming at Plage du Midi (Blue Flag beach)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold">&#9679;</span>
                  <span>Picnic or lakeside restaurant for lunch</span>
                </li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">🍕</span> Evening &mdash; Pizza Night
              </h4>
              <p class="text-charcoal/70 mb-4">
                After a big day on the water, we&rsquo;re keeping dinner easy: pizza night
                at the venue! Order from a local favourite:
              </p>
              <div class="bg-cream rounded-xl p-4">
                <h5 class="font-semibold text-charcoal">Pizza L&eacute;o</h5>
                <p class="text-sm text-charcoal/60 mt-1">
                  Artisan pizzas &amp; burgers &middot; Right here in Epinac!<br/>
                  40+ pizza varieties &middot; &euro;9&ndash;14.50<br/>
                  They also have a food truck for larger events.
                </p>
                <p class="text-sm text-gold-dark mt-2 font-medium">Tel: 07 61 02 52 54</p>
                <a href="https://pizza-leo-71.fr/" target="_blank" rel="noopener"
                   class="text-xs text-wine underline mt-1 inline-block">pizza-leo-71.fr</a>
              </div>
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-wine mb-3">Dinner Out Options</h4>
            <div class="grid sm:grid-cols-3 gap-4">
              <a href="http://lechateaubriant.com/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Le Ch&acirc;teaubriant</h5>
                <p class="text-xs text-charcoal/60 mt-1">Autun &middot; 20 min</p>
              </a>
              <a href="https://labrasseriedeshalles.fr/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">La Brasserie des Halles</h5>
                <p class="text-xs text-charcoal/60 mt-1">Nolay &middot; 30 min</p>
              </a>
              <a href="https://fr.restaurantguru.com/Au-Tire-Bouchon-Nolay" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Au Tire Bouchon</h5>
                <p class="text-xs text-charcoal/60 mt-1">Nolay &middot; 30 min</p>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- July 8 -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-emerald-700 to-emerald-500 p-6 text-white">
          <p class="text-white/70 text-sm uppercase tracking-wider">Wednesday, July 8</p>
          <h3 class="font-serif text-2xl sm:text-3xl font-bold">Acrobranche &amp; Nature Day 🌲</h3>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid md:grid-cols-2 gap-8 mb-8">
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">🌅</span> Morning &mdash; Acrobranche
              </h4>
              <p class="text-charcoal/70 mb-3">
                <strong>Acrogivry</strong> &mdash; the largest adventure park in Burgundy
                (~40 min drive via Givry). 31 courses with 350+ aerial challenges!
              </p>
              <ul class="space-y-1 text-sm text-charcoal/70">
                <li>&#8226; <strong>Kids (3+):</strong> 13 courses, 1&ndash;8m height</li>
                <li>&#8226; <strong>Teens &amp; adults:</strong> 18 courses up to 20m, giant ziplines</li>
                <li>&#8226; Prices: &euro;14 kids (3-6), &euro;19 young (7-17), &euro;24 adults</li>
              </ul>
              <a href="https://acrogivry.fr/" target="_blank" rel="noopener" class="text-sm text-wine underline mt-2 inline-block">acrogivry.fr</a>
            </div>
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">☀️</span> Afternoon Alternatives
              </h4>
              <p class="text-charcoal/70 mb-3">
                For those who&rsquo;d rather keep their feet on the ground:
              </p>
              <ul class="space-y-2 text-charcoal/70 text-sm">
                <li class="flex items-start gap-2">
                  <span class="text-gold">&#9679;</span>
                  <span><strong>Bibracte</strong> &mdash; Ancient Gaulish capital on Mont Beuvray (~45 min). Museum + archaeological site.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold">&#9679;</span>
                  <span><strong>Autun</strong> &mdash; Roman theatre, medieval cathedral, charming town centre (20 min).</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold">&#9679;</span>
                  <span>Or just relax by the pool!</span>
                </li>
              </ul>
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
              <span class="text-lg">🌙</span> Evening &mdash; Burgundy Night
            </h4>
            <p class="text-charcoal/70">
              A themed dinner at the venue, catered with classic Burgundian cuisine: b&oelig;uf bourguignon,
              escargots, &eacute;poisses cheese, and local wines. A true taste of the region.
            </p>
          </div>
          <div class="mt-6">
            <h4 class="font-semibold text-wine mb-3">Dinner Out Options</h4>
            <div class="grid sm:grid-cols-3 gap-4">
              <a href="http://lechateaubriant.com/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Le Ch&acirc;teaubriant</h5>
                <p class="text-xs text-charcoal/60 mt-1">Autun &middot; 20 min</p>
              </a>
              <a href="https://labrasseriedeshalles.fr/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">La Brasserie des Halles</h5>
                <p class="text-xs text-charcoal/60 mt-1">Nolay &middot; 30 min</p>
              </a>
              <a href="https://fr.restaurantguru.com/Au-Tire-Bouchon-Nolay" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Au Tire Bouchon</h5>
                <p class="text-xs text-charcoal/60 mt-1">Nolay &middot; 30 min</p>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- July 9 -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-amber-600 to-amber-400 p-6 text-white">
          <p class="text-white/70 text-sm uppercase tracking-wider">Thursday, July 9</p>
          <h3 class="font-serif text-2xl sm:text-3xl font-bold">Free Day &amp; Relax 🌻</h3>
        </div>
        <div class="p-6 sm:p-8">
          <p class="text-charcoal/70 mb-6">
            A free day to do whatever you fancy. Here are some ideas, or just enjoy the pool
            and the Burgundy sunshine.
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
            <div class="bg-cream rounded-xl p-5">
              <h5 class="font-semibold text-charcoal mb-1">🏊 Pool Day</h5>
              <p class="text-sm text-charcoal/60">Relax at the venue. Heated pool, terraces, and games.</p>
            </div>
            <div class="bg-cream rounded-xl p-5">
              <h5 class="font-semibold text-charcoal mb-1">🚂 V&eacute;lorail du Morvan</h5>
              <p class="text-sm text-charcoal/60">Pedal-carts on old railway tracks. Great fun for families.</p>
            </div>
            <div class="bg-cream rounded-xl p-5">
              <h5 class="font-semibold text-charcoal mb-1">🦅 Raptor Walk</h5>
              <p class="text-sm text-charcoal/60">&Eacute;chapp&eacute;e Morvan d&rsquo;Ailes &mdash; walk with birds of prey. Educational and magical for kids.</p>
            </div>
            <div class="bg-cream rounded-xl p-5">
              <h5 class="font-semibold text-charcoal mb-1">🥾 Mining Heritage Hike</h5>
              <p class="text-sm text-charcoal/60">Circuit des Gueules Noires (9.5 km, from Epinac). Discover the old mining history.</p>
            </div>
            <div class="bg-cream rounded-xl p-5">
              <h5 class="font-semibold text-charcoal mb-1">🍷 Beaune Day Trip</h5>
              <p class="text-sm text-charcoal/60">The wine capital (40 min). Tasting at Caveau D&eacute;licave in 16th-century cellars.</p>
            </div>
            <div class="bg-cream rounded-xl p-5">
              <h5 class="font-semibold text-charcoal mb-1">🐴 Horse Riding</h5>
              <p class="text-sm text-charcoal/60">Pony rides for kids from age 4 at Les Gambades (&euro;19/h) in the Morvan.</p>
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
              <span class="text-lg">🌙</span> Evening &mdash; Pre-Party Chill
            </h4>
            <p class="text-charcoal/70">
              Cocktails by the pool, early night in. Tomorrow is the big day!
            </p>
          </div>
          <div class="mt-6">
            <h4 class="font-semibold text-wine mb-3">Dinner Out Options</h4>
            <div class="grid sm:grid-cols-3 gap-4">
              <a href="http://lechateaubriant.com/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Le Ch&acirc;teaubriant</h5>
                <p class="text-xs text-charcoal/60 mt-1">Autun &middot; 20 min</p>
              </a>
              <a href="https://labrasseriedeshalles.fr/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">La Brasserie des Halles</h5>
                <p class="text-xs text-charcoal/60 mt-1">Nolay &middot; 30 min</p>
              </a>
              <a href="https://pizza-leo-71.fr/" target="_blank" rel="noopener" class="block bg-cream rounded-xl p-4 hover:shadow-md transition-shadow">
                <h5 class="font-semibold text-charcoal text-sm">Pizza L&eacute;o</h5>
                <p class="text-xs text-charcoal/60 mt-1">Epinac &middot; Takeaway &amp; delivery</p>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- July 10 -->
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-gold-dark via-gold to-gold-light p-6 text-white relative overflow-hidden">
          <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2220%22 height=%2220%22><circle cx=%2210%22 cy=%2210%22 r=%221.5%22 fill=%22white%22/></svg>'); background-size: 20px 20px;"></div>
          <div class="relative">
            <p class="text-white/80 text-sm uppercase tracking-wider">Friday, July 10</p>
            <h3 class="font-serif text-2xl sm:text-3xl font-bold">The Anniversary Party 💍</h3>
          </div>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">☀️</span> Day
              </h4>
              <ul class="space-y-2 text-charcoal/70">
                <li><strong>Morning:</strong> Relaxed brunch at the venue</li>
                <li><strong>Afternoon:</strong> Free time &mdash; pool, relax, or keep the kids busy with the babysitter</li>
                <li><strong>Late afternoon:</strong> Time to get dressed up!</li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold text-wine mb-3 flex items-center gap-2">
                <span class="text-lg">✨</span> The Party
              </h4>
              <ul class="space-y-2 text-charcoal/70">
                <li>🥂 <strong>Ap&eacute;ritif</strong> on the terrace at sunset</li>
                <li>🍽️ <strong>Catered dinner</strong> under the stars</li>
                <li>🎵 <strong>DJ &amp; dancing</strong> until late</li>
                <li>👶 <strong>Kids&rsquo; corner</strong> with babysitter, movies &amp; games in the game room</li>
              </ul>
