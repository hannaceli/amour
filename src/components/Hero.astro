---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-wine-dark via-wine to-wine-light"></div>
  <div class="absolute inset-0 opacity-20" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><circle cx=%2250%22 cy=%2250%22 r=%221%22 fill=%22%23C9A96E%22 opacity=%220.3%22/></svg>'); background-size: 60px 60px;"></div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <p class="font-serif italic text-gold-light text-lg sm:text-xl mb-4 tracking-wide">You are invited to celebrate</p>
    <h1 class="font-serif text-5xl sm:text-7xl lg:text-8xl font-bold text-white mb-4 leading-tight">
      Ten Years<br/>of Amour
    </h1>
    <div class="w-24 h-px bg-gold mx-auto my-8"></div>
    <p class="text-cream/90 text-lg sm:text-xl font-light mb-2">
      July 4 &ndash; 11, 2026
    </p>
    <p class="text-cream/70 text-base sm:text-lg font-light mb-12">
      La Fabrique des Ducs &middot; Epinac, Burgundy, France
    </p>

    <div id="countdown" class="flex justify-center gap-6 sm:gap-10 mb-12">
      <div class="text-center">
        <span id="cd-days" class="block font-serif text-4xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Days</span>
      </div>
      <div class="text-center">
        <span id="cd-hours" class="block font-serif text-4xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Hours</span>
      </div>
      <div class="text-center">
        <span id="cd-mins" class="block font-serif text-4xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Minutes</span>
      </div>
    </div>

    <a href="#venue" class="inline-block bg-gold hover:bg-gold-dark text-white font-medium px-8 py-3 rounded-full transition-colors text-sm uppercase tracking-wider">
      Discover the Week
    </a>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-cream/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
